# Flask
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=change-me

# SQLite
DATABASE_FILE=email_agent.db

# Scheduler
SCHEDULER_ENABLED=true
CHECK_INTERVAL_MINUTES=5

# Gmail API
GOOGLE_CLIENT_SECRETS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly,https://www.googleapis.com/auth/gmail.compose
GMAIL_QUERY=is:unread in:inbox -from:me -category:promotions -category:social

# Gemini API
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash-lite

# App behavior
LOG_LEVEL=INFO
DASHBOARD_PAGE_SIZE=20
